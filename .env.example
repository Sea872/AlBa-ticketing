# Server
NODE_ENV=development
PORT=8000

# PostgreSQL (required for migrate / seed / app DB usage)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/concert_ticketing
# If the database does not exist yet: npm run db:create

# Optional: connect to this DB to run CREATE DATABASE (default: postgres)
# POSTGRES_ADMIN_DATABASE=postgres

# Local seed (npm run seed) — change in production
SEED_ADMIN_EMAIL=seadragon@outlook.com
SEED_ADMIN_PASSWORD=concert_ticket_system_2026_04_07

# Shopify — webhook HMAC uses SHOPIFY_WEBHOOK_SECRET or falls back to SHOPIFY_API_SECRET
# SHOPIFY_WEBHOOK_SECRET=
# SHOPIFY_API_SECRET=
# SHOPIFY_SHOP_DOMAIN=
# SHOPIFY_ACCESS_TOKEN=

# Ticket QR PNG output directory (default: storage/tickets under project root)
# TICKET_STORAGE_DIR=storage/tickets

# Resend (Phase 11) — ticket emails; get key at https://resend.com/api-keys
# RESEND_API_KEY=
# From domain must be verified in Resend for production; onboarding@resend.dev works for tests
# RESEND_FROM=Alba GB <onboarding@resend.dev>

# Admin JWT (required in production; min ~32 random chars)
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# Backups — npm run backup (requires pg_dump + tar on PATH)
# BACKUP_DIR=backups
